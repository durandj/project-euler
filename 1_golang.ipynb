    "\n",
    "result := 0\n",
    "\n",
    "for i := 3; i < 1000; i++ {\n",
    "    if i % 3 == 0 || i % 5 == 0 {\n",
    "        result += i\n",
    "    }\n",
    "}\n",
    "\n",
    "fmt.Println(result)"
